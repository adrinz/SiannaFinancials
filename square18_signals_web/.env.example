# Copy this file to `.env` in the same directory and set your keys ONLY there.
# Never put real keys in this file — it is committed to git.
#
#   cp .env.example .env
#   # then edit .env and fill in your values
#
# Required for Claude (polish, brief, explain endpoints)
ANTHROPIC_API_KEY=

# Optional (default is Claude Sonnet 4.5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Tradier API (for live options and equity data)
TRADIER_API_KEY=
TRADIER_ENV=sandbox  # Change to 'live' when using a funded brokerage account token
