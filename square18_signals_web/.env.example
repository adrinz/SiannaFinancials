# Copy this file to `.env` in the same directory and set your keys ONLY there.
# Never put real keys in this file — it is committed to git.
#
#   cp .env.example .env
#   # then edit .env and fill in your values
#
# Optional LLM provider for polish/brief/explain endpoints.
# Provider options: auto, gemini, anthropic (default auto prefers Gemini).
SQUARE18_LLM_PROVIDER=auto

# Gemini (recommended free tier via Google AI Studio).
GEMINI_API_KEY=
# Optional model override.
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic (optional alternative provider).
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Tradier API (for live options and equity data)
TRADIER_API_KEY=
TRADIER_ENV=sandbox  # Change to 'live' when using a funded brokerage account token
